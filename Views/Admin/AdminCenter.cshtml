@{
}

@model List<Benutzer>


<table class="table-bordered">
    @foreach (var benutzer in Model)
    {
        <tr>
            <td>Name : @benutzer.Vorname @benutzer.Nachname</td>
            <td>Emailadresse : @benutzer.Email</td>
            <td>Rolle : @benutzer.Rolle</td>
            <td></td>
                <a class="btn btn-group btn-success" href="@Url.ActionLink("Auswerten","Admin",new {Auswertung = true, NutzerId = benutzer.ID})">Erlauben</a>
                <a class="btn btn-group btn-danger" href="@Url.ActionLink("Auswerten", "Admin", new {Auswertung = false, NutzerId = benutzer.ID})">Ablehnen</a>
            
        </tr>
    }
</table>
